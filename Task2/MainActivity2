class MainActivity2 : ComponentActivity() {
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        enableEdgeToEdge()
        setContent {
            FirstTheme {
                MainScreen()
            }
        }
    }
}

@Composable
fun MainScreen() {
    val secretNumber = remember { Random.nextInt(0, 100) }
    var userInput by remember { mutableStateOf("") }
    var resultText by remember { mutableStateOf("") }
    var isGuessed by remember { mutableStateOf(false) }

    Column(
        modifier = Modifier
            .fillMaxSize()
            .padding(16.dp),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.Center
    ) {
        if (isGuessed) {
            AsyncImage(
                model = "https://yandex.ru/images/search?img_url=https%3A%2F%2Fgfx.nrk.no%2F5Ugd-_ThaIeZh8lqq_4B1QMkCTKneIaQM0wbbIwZwmPQ&lr=11127&pos=3&rpt=simage&source=serp&text=свинка%20пеппа",
                contentDescription = "Красава!",
                modifier = Modifier.size(200.dp)
            )
        } else {
            Text(
                text = resultText,
                fontSize = 20.sp
            )
        }

        TextField(
            value = userInput,
            onValueChange = { newInput ->
                if (newInput.isEmpty() || newInput.all { it.isDigit() }) {
                    userInput = newInput
                }
            },
            label = { Text("Введите число от 0 до 100") }
        )

        Button(
            onClick = {
                val guess = userInput.toIntOrNull()

                if (guess == null) {
                    resultText = "Введите число"
                } else if (guess < secretNumber) {
                    resultText = "Введенное число меньше загаданного"
                    isGuessed = false
                } else if (guess > secretNumber) {
                    resultText = "Введенное число больше загаданного"
                    isGuessed = false
                } else {
                    isGuessed = true
                }
            }
        ) {
            Text("Проверить")
        }
    }
}

